# Archive — local-only scratch and superseded artifacts
archive/

# ESP-IDF build output
build/
*.elf
*.map

# dependencies.lock is deliberately NOT ignored — it's the ESP-IDF
# component manager's version-pin file and must be tracked for
# reproducible builds if external components are ever added.

# Generated configuration (derived from sdkconfig.defaults)
sdkconfig
sdkconfig.old

# Python / tooling caches
.cache/
.ruff_cache/
.venv*/
__pycache__/
*.pyc

# Local logs and session scratch
*.log
*_log.txt
session-ses_*.md

# Binary payloads and compiled VM images
*.hex
*.rfxv
*.bin

# OS metadata
.DS_Store
Thumbs.db
build-host/
build_esp32/
release/reflex-os-*/
release/*.zip
docs/api/
